---
import SectionTitle from "@/components/SectionTitle.astro";
import { services } from "@/content/services";

const featured = services.filter((service) => service.featured).slice(0, 3);
const items = featured.length ? featured : services.slice(0, 3);
---

<section class="section-pad bg-white">
  <div class="container-page">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionTitle
        eyebrow="Productos"
        title="Soluciones promocionales para cada necesidad de tu marca."
        intro="Desde artículos de uso diario hasta material para eventos y campañas. Personalizamos tu logo en productos útiles, visibles y memorables."
      />
      <a class="btn-secondary md:mb-1" href="/services">Ver todos</a>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {items.map((service) => (
        <article class="card group overflow-hidden transition hover:-translate-y-1">
          <div class="overflow-hidden bg-shell">
            <img
              class="h-56 w-full object-cover transition duration-300 group-hover:scale-105"
              src={service.image}
              alt={`${service.title} — artículos promocionales personalizados de Ideas 360 en Panamá`}
              loading="lazy"
            />
          </div>
          <div class="p-6">
            <p class="text-xs font-semibold uppercase tracking-wide text-rose">{service.category}</p>
            <h3 class="mt-2 font-display text-xl font-semibold text-ink">{service.title}</h3>
            <p class="mt-3 text-sm leading-6 text-cocoa">{service.description}</p>
            <a
              class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-rose hover:text-ink transition-colors"
              href={`/services/${service.slug}`}
            >
              Ver detalles
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
