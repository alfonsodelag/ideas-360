---
import Button from "@/components/Button.astro";
---

<section class="relative overflow-hidden bg-white">
  <div class="absolute inset-y-0 right-0 hidden w-1/2 bg-shell lg:block"></div>
  <div class="container-page relative grid min-h-[calc(100vh-5rem)] items-center gap-12 py-14 lg:grid-cols-[0.95fr_1.05fr] lg:py-20">
    <div class="max-w-2xl">
      <p class="eyebrow">Artículos Promocionales & Material POP · Panamá</p>
      <h1 class="mt-4 font-display text-5xl font-semibold leading-tight text-ink sm:text-6xl">
        Tu logo en todo lo que tu marca necesita para destacar.
      </h1>
      <p class="mt-6 text-lg leading-8 text-cocoa">
        En Ideas 360 desarrollamos artículos promocionales, regalos corporativos, textiles y material POP personalizados para campañas, eventos, empresas e instituciones en Panamá.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <Button href="#contacto" label="Solicitar cotización" />
        <Button href="/services" label="Ver productos" variant="secondary" />
      </div>
      <dl class="mt-10 grid grid-cols-3 gap-4 border-t border-ink/10 pt-8">
        <div>
          <dt class="font-display text-3xl font-bold text-rose">5+</dt>
          <dd class="mt-1 text-xs uppercase tracking-[0.12em] text-cocoa">Categorías</dd>
        </div>
        <div>
          <dt class="font-display text-3xl font-bold text-rose">B2B</dt>
          <dd class="mt-1 text-xs uppercase tracking-[0.12em] text-cocoa">Enfoque</dd>
        </div>
        <div>
          <dt class="font-display text-3xl font-bold text-rose">PTY</dt>
          <dd class="mt-1 text-xs uppercase tracking-[0.12em] text-cocoa">Panamá</dd>
        </div>
      </dl>
    </div>
    <div class="relative">
      <div class="h-[36rem] w-full overflow-hidden rounded-lg shadow-soft">
        <img
          src="/images/hero-bg.jpg"
          alt="Artículos promocionales y bolsas personalizadas de Ideas 360 en Panamá"
          class="h-full w-full object-cover"
          loading="eager"
        />
      </div>
      <div class="absolute bottom-6 left-6 max-w-xs rounded-lg bg-white/92 p-5 shadow-soft backdrop-blur">
        <p class="text-sm font-semibold text-ink">Cotización rápida</p>
        <p class="mt-2 text-sm leading-6 text-cocoa">Cuéntanos qué necesitas y te orientamos con opciones para tu marca, evento o campaña.</p>
      </div>
    </div>
  </div>
</section>
