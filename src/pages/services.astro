---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import Contact from "@/sections/Contact.astro";
import BacPromotion from "@/sections/BacPromotion.astro";
import { servicesByCategory, categories } from "@/content/services";
---

<BaseLayout
  title="Productos Promocionales | Ideas 360 Panamá"
  description="Artículos promocionales, textiles, regalos corporativos, material POP y personalización de marca para empresas y eventos en Panamá. Cotiza con Ideas 360."
>
  <section class="section-pad bg-white">
    <div class="container-page">
      <SectionTitle
        eyebrow="Productos"
        title="Artículos promocionales para cada necesidad de tu marca."
        intro="Encuentra la solución adecuada según el uso, la cantidad y el objetivo de tu campaña, evento o empresa. Trabajamos con distintos volúmenes y presupuestos."
        align="center"
      />

      <div class="mt-10 flex flex-wrap justify-center gap-2">
        {categories.map((cat) => (
          <a
            href={`#${cat.toLowerCase().replace(/\s+/g, "-").replace(/[áéíóúñ]/g, (c: string) => ({á:"a",é:"e",í:"i",ó:"o",ú:"u",ñ:"n"})[c] ?? c)}`}
            class="rounded-full border border-ink/15 bg-cream px-4 py-1.5 text-xs font-semibold text-ink transition hover:border-rose hover:text-rose"
          >
            {cat}
          </a>
        ))}
      </div>
    </div>
  </section>

  {categories.map((cat, i) => {
    const catServices = servicesByCategory[cat] ?? [];
    const anchorId = cat.toLowerCase().replace(/\s+/g, "-").replace(/[áéíóúñ]/g, (c: string) => ({á:"a",é:"e",í:"i",ó:"o",ú:"u",ñ:"n"})[c] ?? c);
    return (
      <section id={anchorId} class={`section-pad ${i % 2 === 0 ? "bg-cream" : "bg-white"}`}>
        <div class="container-page">
          <span class="eyebrow">{cat}</span>
          <h2 class="mt-2 font-display text-2xl font-semibold text-ink">{cat}</h2>
          <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {catServices.map((service) => (
              <article class="card group overflow-hidden transition hover:-translate-y-1">
                <div class="relative overflow-hidden bg-shell">
                  <img
                    class="h-48 w-full object-cover transition duration-300 group-hover:scale-105"
                    src={service.image}
                    alt={`${service.title} — artículos promocionales personalizados para empresas en Panamá`}
                    loading="lazy"
                  />
                </div>
                <div class="p-5">
                  <h3 class="font-display text-lg font-semibold text-ink">{service.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-cocoa line-clamp-2">{service.description}</p>
                  <a
                    class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-rose hover:text-ink transition-colors"
                    href={`/services/${service.slug}`}
                  >
                    Ver detalles
                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    );
  })}

  <BacPromotion />
  <Contact />
</BaseLayout>
