---
import { siteConfig } from "@/config/site";

const quickLinks = [
  { href: "/", label: "Inicio" },
  { href: "/services", label: "Productos" },
  { href: "/about", label: "Soluciones" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contacto" }
];

const categories = [
  "Artículos Promocionales",
  "Regalos Corporativos",
  "Textiles y Uniformes",
  "Material POP",
  "Personalización de Marca"
];
---

<footer class="bg-ink text-white">
  <div class="container-page grid gap-10 py-14 md:grid-cols-[1.4fr_0.8fr_0.8fr]">
    <div>
      <img src="/logo.svg" alt="Ideas 360 — Tu logo en todo" class="h-10 w-auto brightness-0 invert" />
      <p class="mt-3 text-sm font-semibold text-rose">{siteConfig.tagline}</p>
      <p class="mt-4 max-w-sm text-sm leading-6 text-white/70">{siteConfig.description}</p>
      <a class="btn-primary mt-6 bg-rose hover:bg-[#c5151b]" href="#contacto">Solicitar cotización</a>
    </div>
    <div>
      <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-white/60">Contacto</h2>
      <ul class="mt-4 space-y-3 text-sm text-white/80">
        <li>
          <a href={`tel:${siteConfig.phone.replace(/\s|\/|\-/g, "")}`} class="hover:text-white transition">{siteConfig.phone}</a>
        </li>
        <li>
          <a href={`mailto:${siteConfig.email}`} class="hover:text-white transition">{siteConfig.email}</a>
        </li>
        <li class="leading-6">{siteConfig.address}</li>
        {siteConfig.social.instagram && (
          <li>
            <a
              href={siteConfig.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white transition"
            >
              @ideas360pty
            </a>
          </li>
        )}
      </ul>
    </div>
    <div>
      <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-white/60">Categorías</h2>
      <ul class="mt-4 space-y-3 text-sm text-white/80">
        {categories.map((cat) => (
          <li>
            <a href="/services" class="hover:text-white transition">{cat}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10 py-5">
    <div class="container-page flex flex-col gap-2 text-xs text-white/55 sm:flex-row sm:items-center sm:justify-between">
      <p>© {new Date().getFullYear()} {siteConfig.businessName}. Todos los derechos reservados.</p>
      <div class="flex items-center gap-4">
        {quickLinks.map((link) => (
          <a href={link.href} class="hover:text-white/80 transition">{link.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
